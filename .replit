modules = ["python-3.11"]
entrypoint = "main.py"
run = "python3 main.py"

[nix]
channel = "stable-24_05"

[deployment]
deploymentTarget = "autoscale"
run = ["python3", "main.py"]

[[ports]]
localPort = 5000
externalPort = 80

[agent]
expertMode = true
integrations = ["python_openai_ai_integrations:1.0.0", "github:1.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python main.py"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"
